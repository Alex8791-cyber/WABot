# Required
OPENAI_API_KEY=sk-...
ADMIN_TOKEN=your-admin-secret

# LLM
MODEL_NAME=gpt-4o-mini
VISION_MODEL=gpt-4o

# Server
ALLOWED_ORIGINS=http://localhost:8080
DATABASE_FILE=service_bot.db

# Thresholds
HANDOFF_THRESHOLD=2
MAX_MESSAGE_LENGTH=10000
MAX_HISTORY_MESSAGES=40

# Rate Limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60

# WhatsApp
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_LANG=de

# Paystack Payments
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co

# Google Calendar
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=primary

# Business Location
BUSINESS_ADDRESS=
BUSINESS_LAT=0
BUSINESS_LNG=0
TIMEZONE=Africa/Johannesburg

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Multimedia (optional)
ENABLE_AUDIO=false
ENABLE_IMAGES=false
ENABLE_TTS=false
